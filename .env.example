# Supabase (Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side only, never expose in dashboard/app.js

# SendGrid (Settings > API Keys)
SENDGRID_API_KEY=SG.your-key-here
ALERT_EMAIL_FROM=alerts@brandywinechemicalworks.com
ALERT_EMAIL_TO=brandywinechemicalworks@gmail.com

# Alerting behavior
PRICE_ALERT_THRESHOLD_PCT=5.0
